# ──────────────────────────────────────────────────────────────
# ForgeUI Server — Environment Variables
# Copy to .env and adjust as needed. All values shown are defaults.
# ──────────────────────────────────────────────────────────────

# Path to the SQLite database file (server + connect)
# FORGEUI_DB_PATH=./forgeui.db

# Comma-separated CORS origins. Use '*' to allow all.
# FORGEUI_CORS_ORIGINS=http://localhost,http://127.0.0.1

# Max request body size in bytes (default: 1 MB)
# FORGEUI_MAX_BODY_BYTES=1048576

# Trust X-Forwarded-For header from reverse proxy (1/true/yes)
# FORGEUI_TRUST_PROXY=

# API bearer token for write endpoints (POST/PUT/PATCH/DELETE)
# Without this, writes are unauthenticated in production.
# FORGEUI_API_TOKEN=

# Rate limiting (set RPM=0 or DISABLE=1 to turn off)
# FORGEUI_RATE_LIMIT_RPM=60
# FORGEUI_RATE_LIMIT_BURST=120
# FORGEUI_RATE_LIMIT_DISABLE=

# Override runtime JS file paths (auto-detected by default)
# FORGEUI_RUNTIME_PATH=
# FORGEUI_STANDALONE_PATH=

# Node environment (affects auth warning)
# NODE_ENV=production
