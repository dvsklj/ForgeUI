# ForgeUI Server environment variables
# Copy to .env and adjust for your deployment.

# Comma-separated CORS origins. Use "*" to allow all origins.
# FORGEUI_CORS_ORIGINS=http://localhost,http://127.0.0.1

# Max request body size in bytes.
# FORGEUI_MAX_BODY_BYTES=1048576

# Trust X-Forwarded-For / X-Real-IP from a reverse proxy.
# FORGEUI_TRUST_PROXY=

# Per-IP requests per minute on /api/*.
# FORGEUI_RATE_LIMIT_RPM=60

# Token-bucket burst size. Defaults to FORGEUI_RATE_LIMIT_RPM * 2.
# FORGEUI_RATE_LIMIT_BURST=120

# Disable rate limiting entirely.
# FORGEUI_RATE_LIMIT_DISABLE=

# Bearer token for /api/apps/* write operations.
# FORGEUI_API_TOKEN=

# Override runtime JS file paths. Usually auto-detected.
# FORGEUI_RUNTIME_PATH=
# FORGEUI_STANDALONE_PATH=

# Enables production warnings for missing auth configuration.
# NODE_ENV=production
