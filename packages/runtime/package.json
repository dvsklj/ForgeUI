{
  "name": "@nedast/forgeui-runtime",
  "version": "0.1.0",
  "description": "Client-side renderer for Forge declarative UI manifests.",
  "main": "forgeui-standalone.js",
  "module": "forgeui-standalone.js",
  "types": "forgeui-standalone.d.ts",
  "exports": {
    ".": {
      "types": "./forgeui-standalone.d.ts",
      "default": "./forgeui-standalone.js"
    },
    "./standalone": {
      "types": "./forgeui-standalone.d.ts",
      "default": "./forgeui-standalone.js"
    },
    "./components": "./forgeui-components.js",
    "./forgeui.js": "./forgeui.js"
  },
  "files": [
    "forgeui.js",
    "forgeui-standalone.js",
    "forgeui-standalone.d.ts",
    "forgeui-components.js",
    "index.d.ts",
    "runtime/",
    "state/",
    "validation/",
    "catalog/",
    "renderer/",
    "tokens/",
    "a2ui/",
    "components/",
    "types/",
    "README.md"
  ],
  "keywords": [
    "llm",
    "web-components",
    "ui",
    "manifest",
    "dynamic-ui",
    "ai-generated",
    "artifact",
    "declarative"
  ],
  "author": "Davor Skulj",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dvsklj/ForgeUI.git",
    "directory": "packages/runtime"
  },
  "bugs": {
    "url": "https://github.com/dvsklj/ForgeUI/issues"
  },
  "homepage": "https://github.com/dvsklj/ForgeUI#readme",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "ajv": "^8.17.0",
    "lit": "^3.2.0",
    "tinybase": "^5.4.0"
  },
  "peerDependenciesMeta": {
    "ajv": { "optional": false },
    "lit": { "optional": false },
    "tinybase": { "optional": false }
  },
  "engines": {
    "node": ">=20"
  }
}