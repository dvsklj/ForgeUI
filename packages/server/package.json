{
  "name": "@forgeui/server",
  "version": "0.1.0",
  "description": "Forge UI server — Hono + SQLite app hosting. Deploy LLM-generated apps as shareable URLs.",
  "main": "dist/forge-server.js",
  "types": "dist/forge-server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/forge-server.d.ts",
      "default": "./dist/forge-server.js"
    }
  },
  "bin": {
    "forgeui-server": "bin/forgeui-server",
    "forgeui": "bin/forgeui"
  },
  "files": [
    "dist/",
    "bin/",
    "README.md"
  ],
  "keywords": [
    "llm",
    "server",
    "app-hosting",
    "sqlite",
    "hono",
    "dynamic-ui",
    "ai-generated"
  ],
  "author": "Davor Skulj",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dvsklj/ForgeUI.git",
    "directory": "packages/server"
  },
  "bugs": {
    "url": "https://github.com/dvsklj/ForgeUI/issues"
  },
  "homepage": "https://github.com/dvsklj/ForgeUI#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "better-sqlite3": "^12.9.0",
    "hono": "^4.12.14"
  },
  "engines": {
    "node": ">=20"
  }
}
