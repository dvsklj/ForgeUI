{
  "manifest": "0.1.0",
  "id": "social-profile",
  "meta": { "title": "Social Profile", "description": "User profile view", "generator": "manual" },
  "root": "shell",
  "state": {
    "profile/following": false,
    "post/liked": false,
    "profile/status": "",
    "profile/tab": "posts"
  },
  "elements": {
    "shell": {
      "type": "Stack",
      "props": { "gap": "none", "padding": "none" },
      "children": ["profile-content"]
    },
    "profile-content": {
      "type": "Stack",
      "props": { "gap": "lg", "padding": "lg" },
      "children": ["profile-card", "profile-status", "stats-grid", "tabs"]
    },
    "profile-card": {
      "type": "Card",
      "props": { "variant": "elevated", "title": "Builder profile", "subtitle": "Product notes and experiments" },
      "children": ["header-row", "bio-text"]
    },
    "header-row": {
      "type": "Stack",
      "props": { "direction": "horizontal", "gap": "md", "align": "center", "wrap": true },
      "children": ["avatar", "name-info", "spacer", "follow-btn"]
    },
    "avatar": { "type": "Avatar", "props": { "name": "Jian-Yang", "size": "lg" } },
    "name-info": {
      "type": "Stack",
      "props": { "gap": "2xs" },
      "children": ["display-name", "username"]
    },
    "display-name": { "type": "Text", "props": { "content": "Jian-Yang", "variant": "heading2" } },
    "username": { "type": "Text", "props": { "content": "@jianyang", "variant": "muted" } },
    "spacer": { "type": "Spacer", "props": { "width": "100%" } },
    "follow-btn": { "type": "Button", "props": { "label": "Follow", "variant": "primary", "action": "follow-profile" } },

    "profile-status": {
      "type": "Alert",
      "visible": { "$when": { "path": "profile/status", "neq": "" } },
      "props": { "variant": "success", "title": "Profile action", "message": "{{$state:profile/status}}" }
    },

    "bio-text": { "type": "Text", "props": { "content": "Building compact tools, strange prototypes, and a better internet one release at a time.", "variant": "body" } },

    "stats-grid": {
      "type": "Grid",
      "props": { "columns": 3, "gap": "md" },
      "children": ["stat-posts", "stat-followers", "stat-following"]
    },
    "stat-posts": { "type": "Metric", "props": { "label": "Posts", "value": "142" } },
    "stat-followers": { "type": "Metric", "props": { "label": "Followers", "value": "12.4K" } },
    "stat-following": { "type": "Metric", "props": { "label": "Following", "value": "3" } },

    "tabs": {
      "type": "Tabs",
      "props": {
        "items": [
          { "label": "Posts", "id": "posts" },
          { "label": "Media", "id": "media" },
          { "label": "Likes", "id": "likes" }
        ],
        "bind": "$state:profile/tab"
      },
      "children": ["tab-posts", "tab-media", "tab-likes"]
    },
    
    "tab-posts": {
      "type": "Container",
      "props": { "slot": "posts" },
      "children": ["post-1"]
    },
    "post-1": {
      "type": "Card",
      "props": {},
      "children": ["p1-stack"]
    },
    "p1-stack": {
      "type": "Stack",
      "props": { "gap": "xs" },
      "children": ["p1-meta", "p1-content", "p1-actions"]
    },
    "p1-meta": { "type": "Text", "props": { "content": "Jian-Yang • 2h ago", "variant": "muted" } },
    "p1-content": { "type": "Text", "props": { "content": "I make a new internet. Faster. Better." } },
    "p1-actions": {
      "type": "ButtonGroup",
      "props": {},
      "children": ["p1-like", "p1-rt"]
    },
    "p1-like": { "type": "Button", "props": { "label": "Like (420)", "variant": "ghost", "action": "like-post" } },
    "p1-rt": { "type": "Button", "props": { "label": "Share", "variant": "ghost", "action": "share-post" } },

    "tab-media": { "type": "Container", "props": { "slot": "media", "padding": "md" }, "children": ["media-empty"] },
    "media-empty": { "type": "Text", "props": { "content": "No media found.", "variant": "muted" } },

    "tab-likes": { "type": "Container", "props": { "slot": "likes", "padding": "md" }, "children": ["likes-empty"] },
    "likes-empty": { "type": "Text", "props": { "content": "No likes found.", "variant": "muted" } }
  },
  "actions": {
    "follow-profile": {
      "type": "mutateState",
      "set": {
        "profile/following": true,
        "profile/status": "You are now following Jian-Yang."
      }
    },
    "like-post": {
      "type": "mutateState",
      "set": {
        "post/liked": true,
        "profile/status": "Post liked."
      }
    },
    "share-post": {
      "type": "mutateState",
      "path": "profile/status",
      "operation": "set",
      "value": "Share link copied."
    }
  }
}
