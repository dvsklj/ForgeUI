{
  "manifest": "0.1.0",
  "id": "habit-tracker",
  "meta": { "title": "Habits", "description": "Daily habit tracking", "generator": "manual" },
  "root": "shell",
  "elements": {
    "shell": {
      "type": "Stack",
      "props": { "gap": "24", "padding": "24" },
      "children": ["header-grid", "habit-list"]
    },
    "header-grid": {
      "type": "Grid",
      "props": { "columns": 2, "gap": "16" },
      "children": ["title", "streak"]
    },
    "title": { "type": "Text", "props": { "content": "Daily Habits", "variant": "heading1" } },
    "streak": { "type": "Metric", "props": { "label": "Current Streak", "value": "14 Days", "trend": "up" } },

    "habit-list": {
      "type": "Stack",
      "props": { "gap": "16" },
      "children": ["h1-card", "h2-card", "h3-card"]
    },
    
    "h1-card": {
      "type": "Card",
      "props": { "title": "Drink 2L Water" },
      "children": ["h1-stack"]
    },
    "h1-stack": {
      "type": "Stack",
      "props": { "direction": "horizontal", "gap": "16", "align": "center" },
      "children": ["h1-progress", "h1-done"]
    },
    "h1-progress": { "type": "Progress", "props": { "value": 100, "max": 100 } },
    "h1-done": { "type": "Checkbox", "props": { "label": "Done", "checked": true } },

    "h2-card": {
      "type": "Card",
      "props": { "title": "Read 20 Pages" },
      "children": ["h2-stack"]
    },
    "h2-stack": {
      "type": "Stack",
      "props": { "direction": "horizontal", "gap": "16", "align": "center" },
      "children": ["h2-progress", "h2-done"]
    },
    "h2-progress": { "type": "Progress", "props": { "value": 100, "max": 100 } },
    "h2-done": { "type": "Checkbox", "props": { "label": "Done", "checked": true } },

    "h3-card": {
      "type": "Card",
      "props": { "title": "Meditate 10 Mins" },
      "children": ["h3-stack"]
    },
    "h3-stack": {
      "type": "Stack",
      "props": { "direction": "horizontal", "gap": "16", "align": "center" },
      "children": ["h3-progress", "h3-done"]
    },
    "h3-progress": { "type": "Progress", "props": { "value": 0, "max": 100 } },
    "h3-done": { "type": "Checkbox", "props": { "label": "Done", "checked": false } }
  }
}
