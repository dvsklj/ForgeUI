{
  "manifest": "0.1.0",
  "id": "issue-tracker",
  "meta": { "title": "Bugs", "description": "Issue tracking table", "generator": "manual" },
  "state": {
    "issues": [
      { "id": "FRG-102", "title": "Memory leak in renderer", "status": "open", "priority": "high", "assignee": "davor" },
      { "id": "FRG-103", "title": "Add DatePicker component", "status": "in-progress", "priority": "medium", "assignee": "alice" },
      { "id": "FRG-104", "title": "Typo in README.md", "status": "resolved", "priority": "low", "assignee": "unassigned" }
    ],
    "modal_open": false,
    "issue/title": "",
    "issue/description": ""
  },
  "root": "shell",
  "elements": {
    "shell": {
      "type": "Stack",
      "props": { "gap": "lg", "padding": "lg", "align": "stretch" },
      "children": ["header-actions", "issue-status", "table-card", "new-issue-modal"]
    },
    "header-actions": {
      "type": "Stack",
      "props": { "direction": "horizontal", "gap": "md", "align": "center" },
      "children": ["page-title", "spacer", "new-btn"]
    },
    "page-title": { "type": "Text", "props": { "content": "Backlog", "variant": "heading1" } },
    "spacer": { "type": "Spacer", "props": { "width": "100%" } },
    "new-btn": { "type": "Button", "props": { "label": "New Issue", "variant": "primary", "action": "open-new-issue" } },

    "issue-status": {
      "type": "Alert",
      "visible": { "$when": { "path": "issue/status", "exists": true } },
      "props": { "variant": "success", "title": "Issue created", "message": "{{$state:issue/status}}" }
    },

    "table-card": {
      "type": "Card",
      "props": { "title": "Sprint queue", "subtitle": "Prioritized issues with current ownership." },
      "children": ["issue-table"]
    },
    "issue-table": {
      "type": "Table",
      "props": {
        "data": { "$expr": "state.issues" },
        "selectable": true,
        "columns": [
          { "key": "id", "label": "ID", "type": "text" },
          { "key": "title", "label": "Title", "type": "text" },
          { "key": "status", "label": "Status", "type": "badge", "badgeMap": { "open": "error", "in-progress": "warning", "resolved": "success" } },
          { "key": "priority", "label": "Priority", "type": "text" },
          { "key": "assignee", "label": "Assignee", "type": "text" }
        ]
      }
    },

    "new-issue-modal": {
      "type": "Dialog",
      "props": { "title": "Create New Issue", "open": { "$expr": "state.modal_open" } },
      "children": ["modal-form"]
    },
    "modal-form": {
      "type": "Stack",
      "props": { "gap": "md" },
      "children": ["m-title", "m-desc", "m-actions"]
    },
    "m-title": { "type": "TextInput", "props": { "label": "Title", "required": true, "bind": "$state:issue/title" } },
    "m-desc": { "type": "TextInput", "props": { "label": "Description", "bind": "$state:issue/description" } },
    "m-actions": {
      "type": "Stack",
      "props": { "direction": "horizontal", "gap": "xs" },
      "children": ["btn-cancel", "btn-create"]
    },
    "btn-cancel": { "type": "Button", "props": { "label": "Cancel", "variant": "ghost", "action": "close-new-issue" } },
    "btn-create": { "type": "Button", "props": { "label": "Create", "variant": "primary", "action": "create-new-issue" } }
  },
  "actions": {
    "open-new-issue": {
      "type": "mutateState",
      "path": "modal_open",
      "operation": "set",
      "value": true
    },
    "close-new-issue": {
      "type": "mutateState",
      "path": "modal_open",
      "operation": "set",
      "value": false
    },
    "close": {
      "type": "mutateState",
      "path": "modal_open",
      "operation": "set",
      "value": false
    },
    "create-new-issue": {
      "type": "mutateState",
      "set": {
        "modal_open": false,
        "issue/status": "Draft saved for {{$state:issue/title}}."
      }
    }
  }
}
